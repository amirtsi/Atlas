# Copy to .env.evolution (gitignored) and fill in a strong key.
#   cp .env.evolution.example .env.evolution

# The master API key for Evolution. Atlas uses this same value as the provider api_key.
# Generate one, e.g.:  openssl rand -hex 24
EVOLUTION_API_KEY=change-me-to-a-long-random-string

# Optional overrides:
# Host port for Evolution (container always listens on 8080 internally).
# 8081 is taken by ParkNet, so the default is 8083. Change if 8083 is also busy.
# EVOLUTION_PORT=8083
# Pin/upgrade the Evolution image tag if needed (official namespace: evoapicloud).
# EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
# Public/base URL Evolution advertises (used for media + callback URLs). Match EVOLUTION_PORT.
# EVOLUTION_SERVER_URL=http://127.0.0.1:8083
